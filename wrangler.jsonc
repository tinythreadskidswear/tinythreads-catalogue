{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tinythreads-catalogue",
  "compatibility_date": "2026-04-26",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/products/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
